###  http://www.di.uminho.pt/rpcw2026/PG61516#wonByGame
rpcw:wonByGame rdf:type owl:ObjectProperty ;
               rdfs:domain rpcw:Premio ;
               rdfs:range rpcw:Jogo .


#################################################################
#    Data properties
#################################################################

###  http://www.di.uminho.pt/rpcw2026/PG61516#category

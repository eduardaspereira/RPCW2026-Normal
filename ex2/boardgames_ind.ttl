#################################################################
#    Object Properties
#################################################################

###  http://www.di.uminho.pt/rpcw2026/PG61516#designedGame
rpcw:designedGame rdf:type owl:ObjectProperty ;
                  rdfs:domain rpcw:Autor ;
                  rdfs:range rpcw:Jogo .


###  http://www.di.uminho.pt/rpcw2026/PG61516#publishedGame
rpcw:publishedGame rdf:type owl:ObjectProperty ;
                   rdfs:domain rpcw:Editora ;
                   rdfs:range rpcw:Jogo .


###  http://www.di.uminho.pt/rpcw2026/PG61516#usedInGame
rpcw:usedInGame rdf:type owl:ObjectProperty ;
                rdfs:domain rpcw:Mecanica ;

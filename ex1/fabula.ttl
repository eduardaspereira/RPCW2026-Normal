@prefix : <http://www.semanticweb.org/fabulas/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/fabulas/> .

<http://www.semanticweb.org/fabulas> rdf:type owl:Ontology .

#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/fabulas#enganou
:enganou rdf:type owl:ObjectProperty ;
         rdfs:domain :Personagem ;
         rdfs:range :Personagem .


###  http://www.semanticweb.org/fabulas#localizadoEm
:localizadoEm rdf:type owl:ObjectProperty ;
              rdfs:domain [ rdf:type owl:Class ;
                            owl:unionOf ( :Objeto
                                          :Personagem
                                        )
                          ] ;
              rdfs:range :Objeto .


###  http://www.semanticweb.org/fabulas#possuiObjeto
:possuiObjeto rdf:type owl:ObjectProperty ;
              rdfs:domain :Personagem ;
              rdfs:range :Objeto .


###  http://www.semanticweb.org/fabulas#temCaracteristica
:temCaracteristica rdf:type owl:ObjectProperty ;
                   rdfs:domain :Personagem ;
                   rdfs:range :Sentimento_Caracteristica .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/fabulas#nome
:nome rdf:type owl:DatatypeProperty ;
      rdfs:range xsd:string .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/fabulas#Animal
:Animal rdf:type owl:Class ;
        rdfs:subClassOf :Personagem .


###  http://www.semanticweb.org/fabulas#Corvo
:Corvo rdf:type owl:Class ;
       rdfs:subClassOf :Animal .


###  http://www.semanticweb.org/fabulas#Objeto
:Objeto rdf:type owl:Class .


###  http://www.semanticweb.org/fabulas#Personagem
:Personagem rdf:type owl:Class .


###  http://www.semanticweb.org/fabulas#Raposa
:Raposa rdf:type owl:Class ;
        rdfs:subClassOf :Animal .


###  http://www.semanticweb.org/fabulas#Sentimento_Caracteristica
:Sentimento_Caracteristica rdf:type owl:Class .


#################################################################
#    Individuals
#################################################################

###  http://www.semanticweb.org/fabulas#Astúcia
:Astúcia rdf:type owl:NamedIndividual ,
                  :Sentimento_Caracteristica .


###  http://www.semanticweb.org/fabulas#Confusão
:Confusão rdf:type owl:NamedIndividual ,
                   :Sentimento_Caracteristica .


###  http://www.semanticweb.org/fabulas#Mestre_Corvo
:Mestre_Corvo rdf:type owl:NamedIndividual ,
                       :Corvo ;
              :localizadoEm :Árvore ;
              :possuiObjeto :Queijo ;
              :temCaracteristica :Confusão ,
                                 :Vaidade ,
                                 :Vergonha .


###  http://www.semanticweb.org/fabulas#Mestre_Raposa
:Mestre_Raposa rdf:type owl:NamedIndividual ,
                        :Raposa ;
               :enganou :Mestre_Corvo ;
               :temCaracteristica :Astúcia .


###  http://www.semanticweb.org/fabulas#Queijo
:Queijo rdf:type owl:NamedIndividual ,
                 :Objeto .


###  http://www.semanticweb.org/fabulas#Vaidade
:Vaidade rdf:type owl:NamedIndividual ,
                  :Sentimento_Caracteristica .


###  http://www.semanticweb.org/fabulas#Vergonha
:Vergonha rdf:type owl:NamedIndividual ,
                   :Sentimento_Caracteristica .


###  http://www.semanticweb.org/fabulas#Árvore
:Árvore rdf:type owl:NamedIndividual ,
                 :Objeto .


